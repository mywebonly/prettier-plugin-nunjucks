{
  "name": "prettier-plugin-nunjucks",
  "version": "0.1.0",
  "description": "Prettier plugin for formatting Nunjucks (.njk) templates",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
