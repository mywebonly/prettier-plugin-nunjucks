{% from "components/general/consent-notice/consent-notice.njk" import render as consentNotice %}
{% from "components/general/breadcrumbs/breadcrumbs.njk" import render as breadcrumbsComponent %}

<!DOCTYPE html>
<html lang="ru">
    <head>
        {% include "blocks/general/meta/meta.njk" %}
        <link rel="stylesheet" href="./css/bundle.css" />
    </head>
    <body>
        <div class="site">
            {% include "components/general/preloader/preloader.njk" %}

            {% include "blocks/general/header/header.njk" %}
            <main class="page">
                {% set page = page | default({}) %}
                {% set page = {
                    breadcrumbs: page.breadcrumbs | default(true),
                    heading: page.heading | default(true),
                    after_content: page.after_content | default(false),
                    sidebar: page.sidebar | default(false),
                    sidebar_position: page.sidebar_position | default("left"),
                    sidebar_class: page.sidebar_class | default("")
                } %}

                {% if page.breadcrumbs or page.heading %}
                    <div class="page-header">
                        {% if page.breadcrumbs %}
                            {{ breadcrumbsComponent(items=breadcrumbs.items, size="sm", separator="slash") }}
                        {% endif %}
                        {% if page.heading %}
                            {% include "components/general/heading/heading.njk" %}
                        {% endif %}
                    </div>
                {% endif %}

                <div class="page-container{% if page.sidebar %} has-sidebar sidebar-{{ page.sidebar_position }}{% if page.sidebar_class %} {{ page.sidebar_class }}{% endif %}{% endif %}">
                    {% if page.sidebar %}
                        <aside class="page-sidebar">
                            <div class="inner">{% block sidebar %}{% endblock %}</div>
                        </aside>
                    {% endif %}
                    <div class="page-content">{% block content %}{% endblock %}</div>
                </div>

                {% if page.after_content %}
                    <div class="page-footer">{% block after_content %}{% endblock %}</div>
                {% endif %}
            </main>
            {% include "blocks/general/footer/footer.njk" %}

            {% include "components/general/menu/menu.njk" %}

            {% include "components/common/popup-callback/popup-callback.njk" %}
            {% include "components/common/popup-callback-success/popup-callback-success.njk" %}
            {% include "components/common/popup-feedback/popup-feedback.njk" %}
            {% include "components/common/popup-feedback-success/popup-feedback-success.njk" %}
            {% include "components/common/popup-order-success/popup-order-success.njk" %}
            {% include "components/common/popup-price/popup-price.njk" %}
            {% include "components/common/popup-invoice/popup-invoice.njk" %}

            {% set consentContent %}
                Мы используем файлы cookie и сервис веб-аналитики Яндекс Метрика для улучшения работы сайта. Оставаясь на сайте, вы соглашаетесь с <a href="./policy.html">Политикой конфиденциальности</a>.
            {% endset %}
            {{ consentNotice(content=consentContent) }}
        </div>
        <script src="./js/bundle.js"></script>
    </body>
</html>
